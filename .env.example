AI_MAX_TOKENS_LIMIT=


#分渠道代理开关
PROXY_AI_ENABLED=false
PROXY_NTFY_ENABLED=false
PROXY_GOTIFY_ENABLED=false
PROXY_BARK_ENABLED=false
PROXY_WX_BOT_ENABLED=false
PROXY_WX_APP_ENABLED=false
PROXY_TELEGRAM_ENABLED=false
PROXY_WEBHOOK_ENABLED=false
PROXY_DINGTALK_ENABLED=false

# 日志配置
# 日志等级: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO
# 控制台输出等级
LOG_CONSOLE_LEVEL=INFO
# 日志目录
LOG_DIR=logs
# 单文件最大大小（字节，默认10MB）
LOG_MAX_BYTES=10485760
# 保留备份数量
LOG_BACKUP_COUNT=10
# 日志保留天数
LOG_RETENTION_DAYS=7
# 文件使用JSON格式（true/false）
LOG_JSON_FORMAT=true
# 是否保留旧的fetcher.log兼容输出（true/false）
LOG_ENABLE_LEGACY=true

# ============== v1.0.0 多用户配置 ==============
# 存储后端: local(本地文件) 或 postgres(PostgreSQL)
STORAGE_BACKEND=local

# PostgreSQL 连接URL (仅当 STORAGE_BACKEND=postgres 时需要)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=

# 敏感数据加密主密钥 (生产环境必须修改!)
ENCRYPTION_MASTER_KEY=change-this-in-production

# 初始管理员账号 (仅首次迁移时使用)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=
INIT_ADMIN_EMAIL=

# 会话过期时间（秒，默认7天）
SESSION_EXPIRE_SECONDS=604800

# 多用户模式下是否要求“用户登录后”才启动调度器（true/false）
SCHEDULER_LOGIN_REQUIRED_IN_MULTI_USER=true
