OPENAI_MODEL_NAME=

#其他设置
PCURL_TO_MOBILE=true
NOTIFY_AFTER_TASK_COMPLETE=True
PROXY_URL=
AI_DEBUG_MODE=false
AI_VISION_ENABLED=True
RUN_HEADLESS=true
ENABLE_THINKING=false
ENABLE_RESPONSE_FORMAT=false
