{
  "manifest_version": 3,
  "name": "咸鱼手动更新登录态插件",
  "version": "1.2",
  "description": "提取咸鱼监控机器人所需的登录态和浏览器环境信息",
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.goofish.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/logo/favicon 32x32.png",
    "32": "images/logo/favicon 32x32.png",
    "48": "images/logo/favicon 32x32.png",
    "128": "images/logo/favicon 32x32.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Extract Xianyu Login State",
    "default_icon": {
      "16": "images/logo/favicon 32x32.png",
      "32": "images/logo/favicon 32x32.png"
    }
  }
}
